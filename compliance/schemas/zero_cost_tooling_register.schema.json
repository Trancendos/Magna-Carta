{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "magna-carta/zero_cost_tooling_register.schema.json",
  "title": "Zero-Cost Tooling Register",
  "type": "object",
  "required": ["meta", "tools"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["register_version", "owner"]
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_id", "name", "cost_model", "mandatory"],
        "properties": {
          "tool_id": { "type": "string", "pattern": "^ZCT-[0-9]{3}$" },
          "name": { "type": "string" },
          "cost_model": {
            "type": "string",
            "enum": ["free_oss", "free_tier_no_cc", "free_local_script"]
          },
          "mandatory": { "type": "boolean" },
          "path": { "type": "string" },
          "invoked_by": { "type": "string" }
        }
      }
    },
    "prohibited_mandatory": {
      "type": "array"
    }
  }
}
